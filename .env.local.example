# Supabase (required)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key

# Production site URL (for auth email redirects)
# Production: https://agenthub.mechlintech.com
# Local dev:  http://localhost:3040
NEXT_PUBLIC_SITE_URL=https://agenthub.mechlintech.com

# AI providers: configure at least ONE for AI Recommendation Mode
# Optional: AI_PROVIDER=openai|gemini|groq (default: auto, first configured key wins)

# OpenAI
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Google Gemini
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# Groq
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# BlazeMeter (optional API base override; credentials are configured in Integrations → BlazeMeter)
# BLAZEMETER_API_BASE=https://a.blazemeter.com/api/v4
