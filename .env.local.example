# Supabase (required)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key

# Production site URL (for auth email redirects)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# AI providers — configure at least ONE for AI Recommendation Mode
# Optional: AI_PROVIDER=openai|gemini|groq (default: auto — first configured key wins)

# OpenAI
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Google Gemini
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# Groq
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
