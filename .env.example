# Supabase dev URL
NEXT_PUBLIC_SUPABASE_URL=<YOUR_SUPABASE_URL>
NEXT_PUBLIC_SUPABASE_ANON_KEY=<YOUR_SUPABASE_ANON_KEY>

# Local dev port (used by npm run dev / start)
PORT=3040

# Production site URL (for auth email redirects)
# Production: <YOUR_SITE_URL>

NEXT_PUBLIC_SITE_URL=<YOUR_SITE_URL>

# Optional: capture real agent UI for landing media (see website/README.md)
# CAPTURE_EMAIL=
# CAPTURE_PASSWORD=
# Product access (landing always served at /). false = hide login/signup and block app routes.
NEXT_PUBLIC_PRODUCT_ENABLED=true

# AI providers: configure at least ONE for AI Recommendation Mode
# Optional: AI_PROVIDER=openai|gemini|groq (default: auto, first configured key wins)

# OpenAI
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Google Gemini
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# Groq
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# BlazeMeter (optional API base override; credentials are configured in Integrations → BlazeMeter)
# BLAZEMETER_API_BASE=https://a.blazemeter.com/api/v4
